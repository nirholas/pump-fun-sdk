# PumpFun Swarm — Configuration
# Copy to .env and customize

# ── Server ───────────────────────────────────────────────────────
SWARM_PORT=4000
SWARM_LOG_LEVEL=info

# ── Health Monitoring ────────────────────────────────────────────
SWARM_HEALTH_INTERVAL=10000

# ── Event Buffer ─────────────────────────────────────────────────
SWARM_MAX_EVENTS=5000

# ── Security ─────────────────────────────────────────────────────
# Set an API key to protect REST endpoints (optional)
# SWARM_API_KEY=your-secret-key-here

# ── CORS ─────────────────────────────────────────────────────────
SWARM_CORS_ORIGINS=*

# ── Auto-Start Bots ─────────────────────────────────────────────
# Comma-separated list of bot IDs to start automatically
# Options: telegram-bot, outsiders-bot, channel-bot, websocket-server
# SWARM_AUTO_START=websocket-server
