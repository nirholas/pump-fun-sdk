# Solana RPC endpoint (required)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# API server port
PORT=3100

# SQLite database path
DB_PATH=./data/swarm.db

# Default slippage in basis points (500 = 5%)
DEFAULT_SLIPPAGE_BPS=500

# Maximum SOL per bot position
MAX_POSITION_SOL_PER_BOT=5

# Maximum total SOL across all bots
MAX_TOTAL_POSITION_SOL=50

# Poll interval for feeds (milliseconds)
POLL_INTERVAL_MS=5000

# Log level: debug | info | warn | error
LOG_LEVEL=info
